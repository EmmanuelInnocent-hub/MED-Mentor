rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny Everything
    match /{document=**} {
      allow read, write: if false;
    }

    // Global Safety Helpers
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }

    // 1. User Profiles
    match /users/{userId} {
      function isValidUser(data) {
        return data.uid == userId
          && data.firstName is string && data.firstName.size() <= 100
          && data.rank in ['STUDENT', 'INTERN', 'RESIDENT', 'FELLOW', 'ATTENDING', 'CONSULTANT', 'Student', 'Resident', 'Attending']
          && data.email is string && data.email.size() <= 255
          && (data.createdAt == request.time || data.createdAt == existing().createdAt)
          && (data.get('lastName', '') is string && data.get('lastName', '').size() <= 100)
          && (data.get('title', '') is string && data.get('title', '').size() <= 20)
          && (data.get('institution', '') is string && data.get('institution', '').size() <= 200)
          && (data.get('specialization', '') is string && data.get('specialization', '').size() <= 100)
          && (data.get('bio', '') is string && data.get('bio', '').size() <= 1000)
          && (data.get('knowledgeProgress', 0) is number)
          && (data.get('streak', 0) is number)
          && (data.get('lastLoginAt', request.time) is timestamp);
      }

      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) 
                    && incoming().diff(existing()).affectedKeys().hasOnly([
                        'firstName', 'lastName', 'title', 'rank', 'institution', 
                        'specialization', 'bio', 'knowledgeProgress', 'streak', 'lastLoginAt'
                      ])
                    && isValidUser(incoming());
    }

    // 2. Simulation Sessions
    match /sessions/{sessionId} {
      function isValidSession(data) {
        return isValidId(sessionId)
          && data.userId == request.auth.uid
          && data.caseTitle is string && data.caseTitle.size() <= 200
          && data.completedAt == request.time
          && data.score.overall is number && data.score.overall >= 0 && data.score.overall <= 100;
      }

      // Secure list query enforcement
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      // Creating a new result - relational sync: user must exist
      allow create: if isSignedIn() 
                    && isValidSession(incoming())
                    && exists(/databases/$(database)/documents/users/$(request.auth.uid));
      
      // Sessions are immutable: No updates or deletes allowed by client
      allow update, delete: if false;
    }
  }
}
